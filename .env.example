# Copiar para .env e preencher. No Render: definir as mesmas chaves no painel (Environment).

# --- Obrigatório em produção ---
DJANGO_SECRET_KEY=gerar-string-longa-e-aleatoria
DEBUG=False

# URL pública do site (Stripe success/cancel, emails). Ex.: https://tours-saas.onrender.com
FRONTEND_URL=https://seu-app.onrender.com

# Hosts (opcional). Se omitido com DEBUG=False: localhost,127.0.0.1,.onrender.com
# Para domínio próprio, acrescenta: ALLOWED_HOSTS=seu-app.onrender.com,seudominio.com,.onrender.com
ALLOWED_HOSTS=

# Origens HTTPS para CSRF (vírgula). Obrigatório com HTTPS.
CSRF_TRUSTED_ORIGINS=https://seu-app.onrender.com

# CORS para a API (mesma origem = pode repetir FRONTEND_URL)
CORS_ALLOWED_ORIGINS=https://seu-app.onrender.com

# HTTPS (default True em produção; só False se estiver atrás de outro proxy)
SECURE_SSL_REDIRECT=True

# Base de dados: localmente deixar vazio (SQLite). No Render: ligar PostgreSQL — DATABASE_URL é injetado.
# DATABASE_URL=postgresql://...

# Stripe
STRIPE_SECRET_KEY=sk_live_ou_sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Email (produção: SMTP real)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@seudominio.com
