# Django
DJANGO_SECRET_KEY=change-this-to-a-long-random-string
DEBUG=True

# Stripe (obrigatório para checkout/pagamentos)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# URL do site (usado em links de email e redirects do Stripe)
FRONTEND_URL=http://127.0.0.1:8000

# Email (opcional; default usa consola)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@dilantours.com
